{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["customer", "admin"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Guitar Product",
      "description": "Information about a guitar available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Category (e.g., Electric, Acoustic)" },
        "image": { "type": "string", "format": "uri", "description": "Product image URL" },
        "description": { "type": "string", "description": "Detailed product description" },
        "stock": { "type": "number", "description": "Available inventory" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in a user's shopping cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "quantity": { "type": "number", "description": "Number of items" },
        "addedAt": { "type": "string", "format": "date-time", "description": "When the item was added" }
      },
      "required": ["productId", "quantity"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "A completed purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User who placed the order" },
        "items": { "type": "array", "description": "List of items in the order" },
        "total": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp" }
      },
      "required": ["userId", "items", "total", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Guitar inventory."
    },
    "/users/{userId}/cart/{itemId}": {
      "schema": "CartItem",
      "description": "Shopping cart items for a specific user."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase history."
    }
  }
}
